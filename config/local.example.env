REFERENCE_SOURCE=./reference.mp4
PRODUCT_IMAGE_SOURCE=./product.png
AUDIO_MODE=original
THAI_SCRIPT=ใส่ข้อความภาษาไทยสำหรับคำบรรยายที่นี่
THAI_SRT_SOURCE=
THAI_VOICE_AUDIO_SOURCE=
DURATION_LIMIT_SECONDS=
RIGHTS_CONFIRMED=true
PRODUCT_LOCK_MODE=overlay
PRODUCT_POSITION=center
PRODUCT_SCALE=0.60

# Hermes AI HTTP adapter. Leave these empty to use the built-in local fallback
# renderer for pipeline testing. Fill them when connecting to Hermes AI.
HERMES_BASE_URL=
HERMES_API_KEY=
HERMES_ASSET_MODE=base64
HERMES_VIDEO_MODEL=
HERMES_VISION_MODEL=
HERMES_CAPTION_MODEL=
HERMES_TTS_MODEL=
HERMES_VIDEO_ENDPOINT=/v1/video/generations
HERMES_VISION_ENDPOINT=/v1/video/breakdown
HERMES_CAPTION_ENDPOINT=/v1/captions/thai
HERMES_TTS_ENDPOINT=/v1/audio/speech
HERMES_RESULT_ENDPOINT=/v1/jobs/{job_id}
VISION_COMMAND=
AI_VIDEO_COMMAND=
CAPTION_COMMAND=
TTS_COMMAND=

# Enable these after HERMES_BASE_URL and HERMES_API_KEY are set:
# VISION_COMMAND=python3 adapters/hermes_ai_adapter.py
# AI_VIDEO_COMMAND=python3 adapters/hermes_ai_adapter.py
# CAPTION_COMMAND=python3 adapters/hermes_ai_adapter.py
# TTS_COMMAND=python3 adapters/hermes_ai_adapter.py
ARTIFACT_UPLOAD_COMMAND=
